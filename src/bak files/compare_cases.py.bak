#!/usr/bin/env python3

import os
import argparse
import pandas as pd
from datetime import datetime

# ===============================
# Utility: Load CSV safely
# ===============================

def load_csv(path):
    if not os.path.exists(path):
        print(f"[!] Missing file: {path}")
        return pd.DataFrame()
    return pd.read_csv(path)

# ===============================
# Process Comparison
# ===============================

def compare_processes(base, attack):
    if base.empty or attack.empty:
        return pd.DataFrame()

    base_set = set(base["PID"].astype(str) + "_" + base["ImageFileName"])
    attack_set = set(attack["PID"].astype(str) + "_" + attack["ImageFileName"])

    new_procs = attack_set - base_set

    rows = []
    for item in new_procs:
        pid, name = item.split("_", 1)
        rows.append({"PID": pid, "Process": name})

    return pd.DataFrame(rows)

# ===============================
# Malfind Comparison (RWX)
# ===============================

def compare_malfind(base, attack):
    if attack.empty:
        return pd.DataFrame()

    if "Protection" not in attack.columns:
        return pd.DataFrame()

    rwx = attack[attack["Protection"].str.contains("EXECUTE_READWRITE", na=False)]

    return rwx

# ===============================
# Command Line Detection
# ===============================

def detect_cmdline(df):
    if df.empty:
        return pd.DataFrame()

    df.columns = df.columns.str.replace(" ", "")

    if "CommandLine" in df.columns:
        col = "CommandLine"
    elif "Args" in df.columns:
        col = "Args"
    else:
        return pd.DataFrame()

    patterns = [
        "Add-Type",
        "Atomic",
        "Start-Process",
        "RWXinjection",
        "Invoke-"
    ]

    mask = False
    for pat in patterns:
        mask = mask | df[col].str.contains(pat, case=False, na=False)

    return df[mask]

# ===============================
# Report Generator
# ===============================

def generate_report(out_dir, proc_diff, malfind_diff, cmd_diff):
    now = datetime.utcnow().strftime("%Y-%m-%d %H:%M:%S UTC")

    report_path = os.path.join(out_dir, "comparison_report.md")

    with open(report_path, "w") as f:
        f.write("# Case01 vs Case02 Comparison Report\n\n")
        f.write(f"Generated: {now}\n\n")

        f.write("## New Processes (Attack Only)\n")
        if not proc_diff.empty:
            f.write(proc_diff.to_markdown(index=False))
        else:
            f.write("None\n")

        f.write("\n\n## RWX Memory Regions (malfind)\n")
        if not malfind_diff.empty:
            f.write(malfind_diff[["PID","Process","Protection"]].to_markdown(index=False))
        else:
            f.write("None\n")

        f.write("\n\n## Suspicious Command Lines\n")
        if not cmd_diff.empty:
            f.write(cmd_diff.to_markdown(index=False))
        else:
            f.write("None\n")

    return report_path

# ===============================
# HTML Report
# ===============================

def generate_html(md_path):
    html_path = md_path.replace(".md", ".html")
    with open(md_path, "r") as f:
        content = f.read()

    html_content = f"""
    <html>
    <head><title>Comparison Report</title></head>
    <body>
    <pre>{content}</pre>
    </body>
    </html>
    """

    with open(html_path, "w") as f:
        f.write(html_content)

    return html_path

# ===============================
# Main
# ===============================

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--baseline", required=True)
    parser.add_argument("--attack", required=True)
    parser.add_argument("--out", required=True)
    parser.add_argument("--make-html", action="store_true")
    args = parser.parse_args()

    os.makedirs(args.out, exist_ok=True)

    base_ps = load_csv(os.path.join(args.baseline, "exports/csv/windows.pslist.csv"))
    atk_ps = load_csv(os.path.join(args.attack, "exports/csv/windows.pslist.csv"))

    base_mf = load_csv(os.path.join(args.baseline, "exports/csv/windows.malfind.csv"))
    atk_mf = load_csv(os.path.join(args.attack, "exports/csv/windows.malfind.csv"))

    atk_cmd = load_csv(os.path.join(args.attack, "exports/csv/windows.cmdline.csv"))

    proc_diff = compare_processes(base_ps, atk_ps)
    malfind_diff = compare_malfind(base_mf, atk_mf)
    cmd_diff = detect_cmdline(atk_cmd)

    proc_diff.to_csv(os.path.join(args.out, "process_diff.csv"), index=False)
    malfind_diff.to_csv(os.path.join(args.out, "malfind_diff.csv"), index=False)
    cmd_diff.to_csv(os.path.join(args.out, "cmdline_diff.csv"), index=False)

    md_path = generate_report(args.out, proc_diff, malfind_diff, cmd_diff)

    if args.make_html:
        generate_html(md_path)

    print("[+] Comparison completed successfully")

if __name__ == "__main__":
    main()
